{
  "name": "sap-devsec-scanner-frontend",
  "version": "1.2.1",
  "description": "SAP DevSec Scanner - Vue.js Frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:vite": "vite",
    "dev:json": "json-server --watch db.json --port 3001",
